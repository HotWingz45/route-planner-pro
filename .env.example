# Copy this file to .env and fill in real values.
# .env is already gitignored by the Vite/TanStack Start template — never commit real keys.

# ---- Client-side (exposed to the browser — must be prefixed VITE_) ----
# Supabase → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase → Project Settings → API → anon / public key
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- Server-side only (never exposed to the browser, no VITE_ prefix) ----
# Same values as above, duplicated for server functions (src/lib/supabase/server.ts)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Supabase → Project Settings → API → service_role key (SECRET — bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic → console.anthropic.com → Get API Keys
# Powers the AI chat bar (src/lib/actions/chat.ts). Server-only, never exposed to the client.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Optional: run the chat bar on a local model instead (free) ----
# Point at any Anthropic-compatible endpoint. For Ollama (https://ollama.com):
#   1. ollama pull qwen3.5:2b   (or any tool-calling-capable model)
#   2. Uncomment both lines below. ANTHROPIC_API_KEY is then not required.
# Extraction quality is noticeably lower on small local models than on Claude.
#ANTHROPIC_BASE_URL=http://localhost:11434
#CHAT_MODEL=qwen3.5:2b
